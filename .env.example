# Copy this file to .env and fill in your real values.
# NEVER commit your real .env file to git (it's already in .gitignore).

# Your Airtable Personal Access Token
# Create one at https://airtable.com/create/tokens
# Required scopes: data.records:read, data.records:write
# Required access: your Parfumea WhatsApp Sales CRM base
VITE_AIRTABLE_TOKEN=your_token_here

# Your Airtable Base ID (found in the base URL, e.g. appUSHEx5DfMMPZ7N)
VITE_AIRTABLE_BASE_ID=appUSHEx5DfMMPZ7N

# Table names (only change these if you renamed your tables)
VITE_AIRTABLE_LEADS_TABLE=Leads
VITE_AIRTABLE_MESSAGES_TABLE=Messages
